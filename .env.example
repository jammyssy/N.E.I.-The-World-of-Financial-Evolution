# 复制为 .env 后填入真实值
# cp .env.example .env

# 数据库（开发用 SQLite，生产推荐 PostgreSQL）
DATABASE_URL="file:./dev.db"

# 会话签名密钥（生产环境务必改为强随机 32+ 字符）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# 附件本地存储目录（生产建议改为对象存储 OSS / COS）
UPLOAD_DIR="./uploads"

# GitHub OAuth（在 github.com/settings/developers 创建 OAuth App 获取）
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Anthropic API（AI 转写 GitHub skill 用，console.anthropic.com 获取）
# 不配置则「从 GitHub 导入」功能不可用，其余功能不受影响
ANTHROPIC_API_KEY=""
