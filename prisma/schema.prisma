// PEVC 知识平台 V1.0 数据模型

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- 用户 ----------
model User {
  id           Int      @id @default(autoincrement())
  phone        String   @unique
  nickname     String   @unique
  role         String   // VC / PE / FA
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts     Post[]
  comments  Comment[]
  likes     PostLike[]
  favorites PostFavorite[]
  commentLikes CommentLike[]
  downloadEvents DownloadEvent[]
}

// ---------- 内容 ----------
model Post {
  id           Int      @id @default(autoincrement())
  userId       Int
  title        String
  body         String
  status       String   @default("published") // draft / pending / published / rejected
  viewCount    Int      @default(0)
  commentCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  author       User           @relation(fields: [userId], references: [id])
  skillAsset   SkillAsset?
  tags         PostTag[]
  comments     Comment[]
  attachments  Attachment[]
  likes        PostLike[]
  favorites    PostFavorite[]

  @@index([status, createdAt])
  @@index([createdAt])
  @@index([userId])
}

// ---------- Skill Asset ----------
model SkillAsset {
  id          Int      @id @default(autoincrement())
  postId      Int      @unique
  assetType   String   // prompt / agent-skill / workflow / tool-stack / template / api-script / case-study
  sourceUrl   String?
  installHint String?
  usageNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([assetType])
}

// ---------- 内容标签 ----------
model PostTag {
  id        Int      @id @default(autoincrement())
  postId    Int
  dimension String   // scene / industry / content
  value     String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, dimension, value])
  @@index([dimension, value])
  @@index([postId])
}

// ---------- 附件 ----------
model Attachment {
  id            Int      @id @default(autoincrement())
  postId        Int?
  uploaderId    Int
  fileName      String
  storageKey    String   // 本地路径 / OSS key
  fileSize      Int
  mimeType      String
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())

  post Post? @relation(fields: [postId], references: [id], onDelete: Cascade)
  downloadEvents DownloadEvent[]

  @@index([postId])
  @@index([uploaderId])
}

// ---------- 评论 ----------
model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  parentId  Int?
  userId    Int
  body      String
  likeCount Int      @default(0)
  createdAt DateTime @default(now())

  post     Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent   Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[]     @relation("CommentReplies")
  author   User          @relation(fields: [userId], references: [id])
  likes    CommentLike[]

  @@index([postId])
  @@index([parentId])
}

model CommentLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

// ---------- 点赞 ----------
model PostLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

// ---------- 收藏 ----------
model PostFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
}

// ---------- 下载记录 ----------
model DownloadEvent {
  id           Int      @id @default(autoincrement())
  userId       Int
  attachmentId Int
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([attachmentId])
  @@index([createdAt])
}

// ---------- 短信验证码（MVP 用 DB 模拟） ----------
model SmsCode {
  id        Int      @id @default(autoincrement())
  phone     String
  code      String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}
